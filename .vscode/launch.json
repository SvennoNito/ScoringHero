{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Fixed Debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe", // Hardcode the venv path
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}